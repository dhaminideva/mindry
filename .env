# ─────────────────────────────────────────────
# Mindry — Environment Config (Zero Cost!)
# Copy this to .env — no API keys needed!
# ─────────────────────────────────────────────

# Ollama runs locally for FREE — no API key needed
# Just install Ollama and pull a model (see README)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use — llama3.2 is fast and free
# Other options: mistral, phi3, gemma2
LLM_MODEL=llama3

# App settings
APP_NAME=Mindry
DEBUG=true
PORT=8000

# Confidence threshold before saving a thought (0.0–1.0)
CONFIDENCE_THRESHOLD=0.6
